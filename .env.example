APP_NAME="ZEROHOUR AVIATION"
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://zerohour:zerohour@postgres:5432/zerohour
DATABASE_REPLICA_URL=postgresql+psycopg://zerohour:zerohour@postgres-replica:5432/zerohour
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=15
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_RECYCLE_SECONDS=1800
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_ANNUAL_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
FLIGHTAWARE_API_KEY=
FLIGHTAWARE_WEBHOOK_SECRET=dev-flightaware-secret
DUFFEL_API_KEY=duffel_test_your_key_here
FIREBASE_SERVICE_ACCOUNT_JSON=
APPLE_APNS_KEY=
APPLE_APNS_KEY_ID=
APPLE_TEAM_ID=
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=
CLOUDINARY_URL=
PASSENGER_ENCRYPTION_KEY=change-me-32-byte-passenger-key
CORS_ORIGINS=https://flyzerohour.com,http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=flyzerohour.com,*.flyzerohour.com,localhost,127.0.0.1,testserver
MOUNT_LEGACY_ROUTES=false
BACKUP_RATE_LIMIT_ENABLED=true
AUTH_REGISTER_RATE_LIMIT_PER_HOUR=10
AUTH_LOGIN_RATE_LIMIT_PER_HOUR=20
AUTHENTICATED_RATE_LIMIT_PER_MINUTE=100
ANONYMOUS_RATE_LIMIT_PER_MINUTE=60
DAT_API_KEY=
DAT_API_SECRET=
TRUCKSTOP_API_KEY=
EIA_API_KEY=
OPENWEATHER_API_KEY=
FRED_API_KEY=
SENDGRID_API_KEY=
RESEND_API_KEY=
LOB_API_KEY=
COGNITO_ISSUER=
COGNITO_AUDIENCE=
FORCE_CACHED_MODE=false
PROVIDER_MODE=mock
SIMULATED_SIGNAL_COUNT=12
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
OWNER_RESOLUTION_MODE=mock
BATCHDATA_API_KEY=
BATCHDATA_BASE_URL=https://api.batchdata.com
BATCHDATA_OWNER_LOOKUP_PATH=/api/v1/property/owner
OWNER_RESOLUTION_SESSION_TTL_SECONDS=1800
OWNER_RESOLUTION_DAILY_LIMIT=50
